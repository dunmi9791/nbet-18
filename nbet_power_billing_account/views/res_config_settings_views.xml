<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_nbet" model="ir.ui.view">
            <field name="name">res.config.settings.view.nbet</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <app string="NBET Power Billing" name="nbet_power_billing"
                     groups="nbet_power_billing.group_nbet_admin">

                    <!-- ── Workflow ─────────────────────────────────────── -->
                    <block title="Workflow">
                        <setting string="DISCO Invoice Mode"
                                 help="Controls how DISCO invoices handle the subsidy/grant shortfall.&#10;DRO Only: invoice the DRO portion only.&#10;Full + Credit: invoice gross then create a subsidy credit note.&#10;DRO + Subsidy JE: invoice DRO and post a separate government receivable entry.">
                            <field name="nbet_disco_invoice_mode"/>
                        </setting>
                        <setting string="Auto-Post Invoices"
                                 help="Automatically post (confirm) vendor bills and customer invoices after creation. Leave off to review drafts first.">
                            <field name="nbet_auto_post_invoices"/>
                        </setting>
                        <setting string="Variance Tolerance (%)"
                                 help="GENCO submitted invoice variances within this % are auto-matched; above it triggers a review flag.">
                            <field name="nbet_variance_tolerance_percent"/>
                        </setting>
                        <setting string="Create Analytic Tags"
                                 help="Attach analytic dimensions to accounting lines for billing cycle and participant tracking.">
                            <field name="nbet_create_analytic_tags"/>
                        </setting>
                        <setting string="Subsidy Sponsor (Partner)"
                                 help="The government entity that funds subsidy shortfalls. Required for Invoice Mode 'DRO + Subsidy Receivable JE'.">
                            <field name="nbet_subsidy_partner_id"/>
                        </setting>
                    </block>

                    <!-- ── Revenue Accounts ─────────────────────────────── -->
                    <block title="Revenue Accounts (DISCO Invoices)">
                        <setting string="Capacity Revenue Account"
                                 help="Credit account for capacity charge revenue lines on DISCO invoices.">
                            <field name="nbet_revenue_capacity_account_id"/>
                        </setting>
                        <setting string="Energy Revenue Account"
                                 help="Credit account for energy charge revenue lines on DISCO invoices.">
                            <field name="nbet_revenue_energy_account_id"/>
                        </setting>
                    </block>

                    <!-- ── Expense Accounts ─────────────────────────────── -->
                    <block title="Expense Accounts (GENCO Vendor Bills)">
                        <setting string="Capacity Expense Account"
                                 help="Debit account for capacity charge expense lines on GENCO vendor bills.">
                            <field name="nbet_expense_capacity_account_id"/>
                        </setting>
                        <setting string="Energy Expense Account"
                                 help="Debit account for energy charge expense lines on GENCO vendor bills.">
                            <field name="nbet_expense_energy_account_id"/>
                        </setting>
                    </block>

                    <!-- ── Subsidy / Grant Accounts ─────────────────────── -->
                    <block title="Subsidy and Grant Accounts">
                        <setting string="Subsidy Receivable Account"
                                 help="Receivable account for government subsidy amounts.">
                            <field name="nbet_subsidy_receivable_account_id"/>
                        </setting>
                        <setting string="Grant Receivable Account"
                                 help="Receivable account for grant funding amounts.">
                            <field name="nbet_grant_receivable_account_id"/>
                        </setting>
                        <setting string="Import Charge Account"
                                 help="Account for GENCO import liability charges.">
                            <field name="nbet_import_charge_account_id"/>
                        </setting>
                        <setting string="Adjustment Account"
                                 help="Account for billing adjustments and prior-period corrections.">
                            <field name="nbet_adjustment_account_id"/>
                        </setting>
                    </block>

                    <!-- ── Journals ─────────────────────────────────────── -->
                    <block title="Journals">
                        <setting string="GENCO Payable Journal"
                                 help="Purchase journal used for GENCO vendor bills.">
                            <field name="nbet_payable_journal_id"/>
                        </setting>
                        <setting string="DISCO Receivable Journal"
                                 help="Sales journal used for DISCO customer invoices.">
                            <field name="nbet_receivable_journal_id"/>
                        </setting>
                        <setting string="Subsidy / Grant Journal"
                                 help="Journal used for subsidy receivable and grant journal entries.">
                            <field name="nbet_subsidy_journal_id"/>
                        </setting>
                    </block>

                </app>
            </field>
        </record>
    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_nbet_disco_dro_list" model="ir.ui.view">
            <field name="name">nbet.disco.dro.list</field>
            <field name="model">nbet.disco.dro</field>
            <field name="arch" type="xml">
                <list string="DISCO DRO History"
                      decoration-success="approval_state == 'approved'"
                      decoration-muted="approval_state == 'archived'">
                    <field name="participant_id"/>
                    <field name="effective_from"/>
                    <field name="effective_to"/>
                    <field name="dro_percent" string="DRO %" widget="percentage"/>
                    <field name="subsidy_percent" string="Subsidy %" widget="percentage" optional="show"/>
                    <field name="source_reference" optional="show"/>
                    <field name="approval_state" widget="badge"
                           decoration-success="approval_state == 'approved'"
                           decoration-warning="approval_state == 'draft'"
                           decoration-muted="approval_state == 'archived'"/>
                </list>
            </field>
        </record>

        <record id="view_nbet_disco_dro_form" model="ir.ui.view">
            <field name="name">nbet.disco.dro.form</field>
            <field name="model">nbet.disco.dro</field>
            <field name="arch" type="xml">
                <form string="DISCO DRO Record">
                    <header>
                        <button name="action_approve" type="object" string="Approve"
                                invisible="approval_state != 'draft'"
                                class="btn-primary"
                                groups="nbet_power_billing.group_nbet_settlement_manager"/>
                        <button name="action_archive_dro" type="object" string="Archive"
                                invisible="approval_state == 'archived'"
                                groups="nbet_power_billing.group_nbet_settlement_manager"/>
                        <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                                invisible="approval_state == 'draft'"
                                groups="nbet_power_billing.group_nbet_admin"/>
                        <field name="approval_state" widget="statusbar"
                               statusbar_visible="draft,approved"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="DISCO and Period">
                                <field name="participant_id"/>
                                <field name="effective_from"/>
                                <field name="effective_to" help="Leave blank for open-ended (current) record."/>
                            </group>
                            <group string="DRO Values">
                                <field name="dro_percent" widget="percentage"/>
                                <field name="subsidy_percent" widget="percentage"/>
                                <field name="subsidy_percent_manual"/>
                            </group>
                        </group>
                        <group>
                            <group string="Source / Approval">
                                <field name="source_reference"/>
                                <field name="approved_by" readonly="1"/>
                                <field name="approved_date" readonly="1"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <field name="notes" placeholder="Notes on the authority or rationale for this DRO..."/>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_nbet_disco_dro_search" model="ir.ui.view">
            <field name="name">nbet.disco.dro.search</field>
            <field name="model">nbet.disco.dro</field>
            <field name="arch" type="xml">
                <search>
                    <field name="participant_id"/>
                    <field name="source_reference"/>
                    <filter string="Approved" name="approved" domain="[('approval_state','=','approved')]"/>
                    <filter string="Draft" name="draft" domain="[('approval_state','=','draft')]"/>
                    <filter string="Archived" name="archived" domain="[('approval_state','=','archived')]"/>
                    <group expand="0" string="Group By">
                        <filter string="DISCO" name="by_disco" context="{'group_by': 'participant_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_nbet_disco_dro" model="ir.actions.act_window">
            <field name="name">DISCO DRO History</field>
            <field name="res_model">nbet.disco.dro</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_approved': 1}</field>
        </record>

    </data>
</odoo>

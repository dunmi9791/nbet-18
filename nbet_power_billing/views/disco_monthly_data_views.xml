<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_nbet_disco_monthly_data_list" model="ir.ui.view">
            <field name="name">nbet.disco.monthly.data.list</field>
            <field name="model">nbet.disco.monthly.data</field>
            <field name="arch" type="xml">
                <list string="DISCO Monthly Data">
                    <field name="billing_cycle_id"/>
                    <field name="participant_id"/>
                    <field name="capacity_delivered_mw" string="Cap. Delivered (MW)"/>
                    <field name="energy_delivered_kwh" string="Energy Del. (kWh)" optional="show"/>
                    <field name="applied_dro_percent" string="DRO %" widget="percentage"/>
                    <field name="expected_payable_amount" string="Expected Payable" optional="show"/>
                    <field name="subsidy_amount" string="Subsidy" optional="show"/>
                </list>
            </field>
        </record>

        <record id="view_nbet_disco_monthly_data_form" model="ir.ui.view">
            <field name="name">nbet.disco.monthly.data.form</field>
            <field name="model">nbet.disco.monthly.data</field>
            <field name="arch" type="xml">
                <form string="DISCO Monthly Data">
                    <sheet>
                        <group>
                            <group string="Reference">
                                <field name="billing_cycle_id"/>
                                <field name="participant_id"/>
                            </group>
                        </group>
                        <group>
                            <group string="Delivered Quantities">
                                <field name="capacity_delivered_mw"/>
                                <field name="energy_delivered_kwh"/>
                                <field name="market_allocation_basis"/>
                            </group>
                            <group string="DRO Applied (frozen at billing time)">
                                <field name="applied_dro_id"/>
                                <field name="applied_dro_percent" widget="percentage"/>
                            </group>
                            <group string="Computed Exposures">
                                <field name="expected_payable_amount"/>
                                <field name="subsidy_amount"/>
                                <field name="grant_amount"/>
                            </group>
                        </group>
                        <field name="remarks"/>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="action_nbet_disco_monthly_data" model="ir.actions.act_window">
            <field name="name">DISCO Monthly Data</field>
            <field name="res_model">nbet.disco.monthly.data</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>

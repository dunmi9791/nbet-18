<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_nbet_genco_contract_list" model="ir.ui.view">
            <field name="name">nbet.genco.contract.list</field>
            <field name="model">nbet.genco.contract</field>
            <field name="arch" type="xml">
                <list string="GENCO Contracts"
                      decoration-muted="state in ('expired','archived')"
                      decoration-success="state == 'active'">
                    <field name="contract_code" string="Code"/>
                    <field name="contract_name"/>
                    <field name="participant_id"/>
                    <field name="plant_type" widget="badge"/>
                    <field name="formula_mode" optional="show"/>
                    <field name="base_capacity_tariff" string="Cap. Tariff (₦/MW/h)" optional="show"/>
                    <field name="base_energy_tariff" string="Eng. Tariff (₦/kWh)" optional="show"/>
                    <field name="start_date" optional="show"/>
                    <field name="end_date" optional="show"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'active'"
                           decoration-warning="state == 'draft'"
                           decoration-muted="state in ('expired','archived')"/>
                </list>
            </field>
        </record>

        <record id="view_nbet_genco_contract_form" model="ir.ui.view">
            <field name="name">nbet.genco.contract.form</field>
            <field name="model">nbet.genco.contract</field>
            <field name="arch" type="xml">
                <form string="GENCO Contract">
                    <header>
                        <button name="action_activate" type="object" string="Activate"
                                invisible="state != 'draft'"
                                class="btn-primary"/>
                        <button name="action_expire" type="object" string="Mark Expired"
                                invisible="state != 'active'"/>
                        <button name="action_archive_contract" type="object" string="Archive"
                                invisible="state == 'archived'"/>
                        <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                                invisible="state == 'draft'"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,active,expired"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="contract_name"/>
                            <h1><field name="contract_name" placeholder="Contract Name"/></h1>
                        </div>
                        <group>
                            <group string="Identity">
                                <field name="contract_code"/>
                                <field name="participant_id"/>
                                <field name="plant_type"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                            <group string="Validity">
                                <field name="start_date"/>
                                <field name="end_date"/>
                                <field name="currency_id"/>
                                <field name="state"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Rate Parameters" name="rates">
                                <group>
                                    <group string="Base Tariffs">
                                        <field name="base_capacity_tariff" string="Base Capacity Tariff (₦/MW/h)"/>
                                        <field name="base_energy_tariff" string="Base Energy Tariff (₦/kWh)"/>
                                        <field name="has_capacity_charge"/>
                                        <field name="has_energy_charge"/>
                                    </group>
                                    <group string="Formula Mode">
                                        <field name="formula_mode"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Adjustments" name="adjustments">
                                <group>
                                    <group string="FX Adjustment">
                                        <field name="uses_fx_adjustment"/>
                                        <field name="base_fx_rate" string="Base FX Rate (₦/$)"
                                               invisible="not uses_fx_adjustment"/>
                                    </group>
                                    <group string="TLF Adjustment">
                                        <field name="uses_tlf_adjustment"/>
                                        <field name="base_tlf" invisible="not uses_tlf_adjustment"/>
                                    </group>
                                    <group string="Index Adjustment">
                                        <field name="uses_index_adjustment"/>
                                        <field name="base_index_value" invisible="not uses_index_adjustment"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Tariff Components" name="components">
                                <field name="line_ids">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="component_type"/>
                                        <field name="name"/>
                                        <field name="basis"/>
                                        <field name="value" optional="show"/>
                                        <field name="uom_description" optional="show"/>
                                        <field name="input_type_code" optional="show"/>
                                        <field name="active"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Notes" name="notes">
                                <field name="notes" placeholder="Contract notes, legal references, NERC order numbers..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_nbet_genco_contract_search" model="ir.ui.view">
            <field name="name">nbet.genco.contract.search</field>
            <field name="model">nbet.genco.contract</field>
            <field name="arch" type="xml">
                <search>
                    <field name="contract_name"/>
                    <field name="contract_code"/>
                    <field name="participant_id"/>
                    <filter string="Active" name="active" domain="[('state','=','active')]"/>
                    <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Plant Type" name="by_plant" context="{'group_by': 'plant_type'}"/>
                        <filter string="Formula Mode" name="by_mode" context="{'group_by': 'formula_mode'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_nbet_genco_contract" model="ir.actions.act_window">
            <field name="name">GENCO Contracts</field>
            <field name="res_model">nbet.genco.contract</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_active': 1}</field>
        </record>

    </data>
</odoo>
